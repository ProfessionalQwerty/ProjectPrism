# Local dev: leave VITE_API_URL unset so Vite proxies /api to localhost:19991 (optional local engine)
# VITE_API_URL=

# Production / Vercel / desktop build — Hugging Face engine URL
VITE_API_URL=https://yashshshsh-prism.hf.space

# Shared client key (must match PRISM_CLIENT_API_KEY on the engine)
VITE_PRISM_CLIENT_KEY=

# Supabase GitHub auth (team mode, sessions, realtime)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional: explicit OAuth redirect (defaults to current page origin)
# VITE_SUPABASE_REDIRECT_URL=https://your-app.vercel.app/

# Installer download base — must end with /download, NOT /releases/tag/v0.1.0
# Option A (recommended): always track latest release
VITE_DOWNLOAD_BASE_URL=https://github.com/ProfessionalQwerty/ProjectPrism/releases/latest/download
# Option B: pin a specific version
# VITE_DOWNLOAD_BASE_URL=https://github.com/ProfessionalQwerty/ProjectPrism/releases/download/v0.1.0
